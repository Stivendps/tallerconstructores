function Libro(nombre,materia,ciudad,tamano,color,prestado){
    this.nombre = nombre;
    this.materia = materia;
    this.ciudad = ciudad;
    this.tamano = tamano;
    this.color = color;
    this.prestado = false;
    this.mostrarResultado = ((this.ciudad + this.tamano + this.color) / 3 >= 3);

    console.log(`Estudiante ${nombre}: ${materia} notas: ${ciudad} | ${tamano} | ${color} | aprobo :${this.mostrarResultado}`);
}

